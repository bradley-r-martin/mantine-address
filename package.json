{
  "name": "mantine-address-input",
  "version": "0.0.0",
  "description": "Mantine plugin providing a reusable address input component",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "husky",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "commitlint": "commitlint --edit"
  },
  "peerDependencies": {
    "@mantine/core": ">=7.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^9.15.0",
    "@mantine/core": "^7.14.0",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.4.7",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "mantine",
    "react",
    "address",
    "input"
  ],
  "license": "MIT"
}
